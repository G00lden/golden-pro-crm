{
  servers {
    # Official Cloudflare origin ranges: https://www.cloudflare.com/ips/
    # An untrusted/direct peer never gets to supply the parsed client address.
    trusted_proxies static 173.245.48.0/20 103.21.244.0/22 103.22.200.0/22 103.31.4.0/22 141.101.64.0/18 108.162.192.0/18 190.93.240.0/20 188.114.96.0/20 197.234.240.0/22 198.41.128.0/17 162.158.0.0/15 104.16.0.0/13 104.24.0.0/14 172.64.0.0/13 131.0.72.0/22 2400:cb00::/32 2606:4700::/32 2803:f800::/32 2405:b500::/32 2405:8100::/32 2a06:98c0::/29 2c0f:f248::/32
    trusted_proxies_strict
    client_ip_headers Cf-Connecting-Ip X-Forwarded-For
  }
}

{$CRM_DOMAIN} {
  encode zstd gzip

  header {
    X-Content-Type-Options "nosniff"
    Referrer-Policy "strict-origin-when-cross-origin"
    X-Frame-Options "DENY"
    Permissions-Policy "camera=(), microphone=(), geolocation=()"
    Strict-Transport-Security "max-age=31536000; includeSubDomains"
    -Server
  }

  reverse_proxy crm:8080 {
    # Always overwrite this private application header. Even a client that
    # reaches the origin directly is identified by its real socket address.
    header_up X-Breexe-Client-IP {client_ip}
  }
}

