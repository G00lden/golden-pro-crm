# Breexe Pro CRM environment

# Local and VPS server port.
PORT=3000

# Trust forwarded client-IP headers (cf-connecting-ip / x-real-ip / x-forwarded-for)
# for rate-limiting. Leave "true" behind the Cloudflare Tunnel (the default setup),
# where those headers are the real client IP. Set to "false" only if the origin is
# reachable directly with no fronting proxy — otherwise callers could spoof the
# headers to evade the rate limit.
TRUST_PROXY_HEADERS=true

# Time zone used by maintenance reminder checks.
APP_TIMEZONE=Asia/Riyadh

# Outbound safety. Keep dry_run until official launch.
# dry_run = never send, code = require OUTBOUND_CONFIRM_CODE, allowlist = only test numbers, production = real send.
OUTBOUND_MODE=dry_run
OUTBOUND_CONFIRM_CODE=
OFFICIAL_LAUNCH_APPROVED=false
OUTBOUND_TEST_PHONE_ALLOWLIST=

# Optional: enable daily automatic reminder sending at 10:00 APP_TIMEZONE.
# Keep false until WhatsApp Web is connected and tested.
ENABLE_DAILY_CRON=false
# Production default: 0 10 * * *. Local stress testing can use */10 * * * *.
REMINDER_CRON_SCHEDULE=0 10 * * *

# WhatsApp sending channel: web or cloud_api.
WHATSAPP_PROVIDER=web

# WhatsApp Web linked-device session directory.
# Used only when WHATSAPP_PROVIDER=web. Keep this directory private and persistent on a VPS.
WA_SESSION_DIR=.wa-session
# Safety: the server refuses to start a second WhatsApp socket on the same
# WA_SESSION_DIR while another process still holds it (two senders on one
# session corrupt encryption and make recipients see "Waiting for this
# message"). Set to true only if you must bypass this guard.
WA_IGNORE_SESSION_LOCK=false

# Auto-reply to unanswered WhatsApp CALLS. When a WhatsApp call isn't answered
# (timeout/reject) the caller gets the missed-call WhatsApp message automatically.
# Set true to also immediately reject incoming WhatsApp calls (then reply);
# false (default) lets it ring and only replies if it goes unanswered.
WHATSAPP_AUTO_REJECT_CALLS=false

# WhatsApp Cloud API credentials.
# Used only when WHATSAPP_PROVIDER=cloud_api.
# Kapso.ai users: set version to v22.0, phone number id + system access token are
# shown in the Kapso dashboard. Configure webhook in Meta to:
#   URL:    https://meta-webhooks.kapso.ai/whatsapp
#   Token:  the WHATSAPP_WEBHOOK_VERIFY_TOKEN value below
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_TOKEN=
# Used by GET /webhooks/whatsapp to satisfy Meta's hub.verify_token challenge.
# Generate a random uuid and paste the same value into Meta's webhook config.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Inbound webhook authentication (POST /webhooks/whatsapp). REQUIRED in production —
# without one of these the webhook is refused (503) to block forged inbound messages.
#   WHATSAPP_APP_SECRET: the Meta App Secret. The POST body's x-hub-signature-256
#     header is verified as HMAC-SHA256(rawBody, WHATSAPP_APP_SECRET).
#   WHATSAPP_WEBHOOK_SECRET: a shared secret for forwarders (e.g. Kapso) that can't
#     replay Meta's signature; sender must send it in the x-whatsapp-webhook-secret header.
# Set at least one. In dev/local both may be blank (unsigned POSTs are accepted).
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_SECRET=
# Optional for production reminders through Cloud API:
# create an approved template with one body variable {{1}}, then set its name here.
WHATSAPP_CLOUD_TEMPLATE_NAME=
WHATSAPP_CLOUD_TEMPLATE_MISSED_CALL_CUSTOMER=
WHATSAPP_CLOUD_TEMPLATE_MISSED_CALL_AGENT=
WHATSAPP_HTTP_TIMEOUT_MS=10000
COMMUNICATION_WORKER_ENABLED=true
COMMUNICATION_WORKER_INTERVAL_MS=2000
WHATSAPP_CLOUD_TEMPLATE_LANGUAGE=ar

# Firebase Admin credentials for local/VPS use.
# Use either FIREBASE_SERVICE_ACCOUNT_PATH or FIREBASE_SERVICE_ACCOUNT_JSON.
# Cloud Run can use Application Default Credentials instead.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
# Explicit admin bootstrap. A first registrant is never promoted automatically.
ADMIN_UIDS=
BOOTSTRAP_ADMIN_EMAILS=

# Public URL used after deployment, if needed.
APP_URL=http://localhost:3000

# Secret used to HMAC-sign public invoice share-links (GET /public/invoices/:id).
# REQUIRED in production — the server refuses to start signing links without it.
# Generate a random string (e.g. `openssl rand -hex 32`).
INVOICE_SHARE_SECRET=

# Database provider: firebase or supabase.
# For the cloud backend, use supabase on both server and client build.
DATA_PROVIDER=firebase
VITE_DATA_PROVIDER=firebase

# Supabase project created for this CRM.
# Project ref: rrvyzfedxuzuzgrwvkwf
SUPABASE_URL=https://rrvyzfedxuzuzgrwvkwf.supabase.co
# Keep service role private on the backend only. Never expose it to Vite/browser.
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=https://rrvyzfedxuzuzgrwvkwf.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=

# Cloudflare DNS automation.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_NAME=breexe-pro.com
CLOUDFLARE_RECORD_NAME=crm
CLOUDFLARE_RECORD_TYPE=CNAME
CLOUDFLARE_DNS_TARGET=
# Keep false until the hosting provider verifies the custom domain and SSL.
CLOUDFLARE_PROXIED=false

# Suggested Cloud Run defaults.
CLOUD_RUN_SERVICE=golden-pro-crm
CLOUD_RUN_REGION=me-central1

# Salla OAuth + API sync.
# Published apps on Salla App Store should use Easy Mode by default.
SALLA_AUTH_MODE=easy
SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=
SALLA_REDIRECT_URI=http://localhost:3000/api/integrations/salla/callback
SALLA_SCOPES=offline_access orders.read products.read customers.read
SALLA_SYNC_CRON_ENABLED=false
SALLA_SYNC_CRON_SCHEDULE=*/15 * * * *
SALLA_SYNC_MAX_PAGES=3
SALLA_SYNC_PAGE_SIZE=30
SALLA_CUSTOMER_SYNC_MAX_PAGES=200
SALLA_CUSTOMER_SYNC_PAGE_SIZE=60
SALLA_CUSTOMER_SYNC_INTERVAL_MINUTES=360
SALLA_FETCH_TIMEOUT_MS=15000
SALLA_FETCH_MAX_RETRIES=2
SALLA_FETCH_RETRY_BASE_DELAY_MS=500
SALLA_FETCH_RETRY_MAX_DELAY_MS=30000
SALLA_STATE_SECRET=
SALLA_APP_WEBHOOK_SECRET=
SALLA_APP_OWNER_UID=

# Store webhook integration.
# Endpoint: POST /api/store/webhook
# Send either X-Golden-Webhook-Secret or HMAC SHA-256 in X-Golden-Signature.
STORE_WEBHOOK_SECRET=
STORE_WEBHOOK_OWNER_UID=
STORE_WEBHOOK_DEFAULT_MAINTENANCE_MONTHS=3
# Bookings are created only when Salla sends an appointment date/time and a default technician is configured.
STORE_WEBHOOK_CREATE_BOOKINGS=true
STORE_WEBHOOK_DEFAULT_TECHNICIAN_ID=
STORE_WEBHOOK_DEFAULT_TECHNICIAN_NAME=

# ── Telephony / IVR call routing (Unifonic) ─────────────────────────────────
# A published "main number" plays an IVR menu; the caller's keypress selects a
# department; the call is forwarded to that department's agent. If nobody
# answers, the customer and the agent each get a WhatsApp message.
#
# Provider adapter. Only `unifonic` is implemented today.
TELEPHONY_PROVIDER=unifonic
# The advertised virtual number customers call (used as the forwarded caller ID).
TELEPHONY_MAIN_NUMBER=
# Default ring time before a forward is treated as "no answer" (seconds).
TELEPHONY_RING_TIMEOUT_SEC=20
# Shared secret authenticating inbound telephony webhooks. REQUIRED in production
# (the webhook is refused 503 without it). Set the same value in the Unifonic
# dashboard and send it as the x-telephony-webhook-secret header (or ?secret=).
TELEPHONY_WEBHOOK_SECRET=
# Absolute base URL the provider calls back on for IVR/status webhooks.
# If unset, it is derived from the inbound request host.
PUBLIC_BASE_URL=
# Unifonic Voice API credentials (from your Unifonic account).
UNIFONIC_APP_SID=
UNIFONIC_API_KEY=
UNIFONIC_VOICE_BASE_URL=

# ── Self-hosted phone gateway (NO external provider, NO WhatsApp QR) ─────────
# The company SIM lives in an Android phone running a free automation app
# (MacroDroid/Tasker). It posts call/SMS events to /api/gateway/event and sends
# queued SMS replies from the SIM. See docs/gateway-setup.md.
#
# Static token the phone sends as the x-gateway-token header (or ?token=).
# REQUIRED in production (endpoints refuse 503 without it). Generate a random
# string, e.g. `openssl rand -hex 24`.
GATEWAY_TOKEN=
# Routing on a missed call: "menu" = SMS the caller a department menu and route
# on their digit reply; "direct" = immediately assign the first department/agent.
# Agents within a department are rotated round-robin for fair distribution.
GATEWAY_ROUTING_MODE=menu
# Anti-spam: minutes to suppress a repeated auto-reply to the same caller
# (call retries / repeated missed calls). 0 disables. Default 10.
GATEWAY_REPLY_COOLDOWN_MIN=10

# Development/test fallback only. It is disabled by default and forbidden in
# production, even when SQLite is the data provider.
ALLOW_LOCAL_AUTH=false
VITE_LOCAL_AUTH=false
# Required when ALLOW_LOCAL_AUTH=true; use at least 32 random characters.
# This is server-only and must never use a VITE_ prefix. Signed tokens are
# issued only over loopback for an explicitly allowed hostname.
LOCAL_AUTH_TOKEN=
LOCAL_AUTH_ALLOWED_HOSTS=localhost,127.0.0.1,::1
