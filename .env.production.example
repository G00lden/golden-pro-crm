# Golden Pro CRM production example: Supabase DB + Cloudflare DNS

APP_ENV=production
PORT=8080
APP_TIMEZONE=Asia/Riyadh
FIELDTECH_SERVER_URL=https://fieldtech.example.com
FIELDTECH_INTEGRATION_SECRET=
FIELDTECH_OWNER_UID=
APP_URL=https://crm.breexe-pro.com
CRM_DOMAIN=crm.breexe-pro.com
# This example targets the bundled VPS Caddy, which overwrites the private
# x-breexe-client-ip header from a validated Cloudflare proxy chain.
TRUST_PROXY_HEADERS=true

# Public company number compiled into landing-page WhatsApp and call actions.
# Use an explicit international number; this value is intentionally public.
VITE_PUBLIC_CONTACT_PHONE=

# Outbound safety.
# code = every real message requires OUTBOUND_CONFIRM_CODE from the operator.
OUTBOUND_MODE=code
OUTBOUND_CONFIRM_CODE=
OFFICIAL_LAUNCH_APPROVED=false
OUTBOUND_TEST_PHONE_ALLOWLIST=

# Disable local demo auth in production.
ALLOW_LOCAL_AUTH=false
VITE_LOCAL_AUTH=false

# Database used by the supported VPS deployment.
DATA_PROVIDER=sqlite
VITE_DATA_PROVIDER=sqlite
DB_PATH=.runtime/golden-crm.db

# Optional Supabase deployment. Apply every migration under supabase/migrations
# and run `npm run db:verify` before selecting this provider.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Tap payments stay disabled until a merchant Secret API Key is configured and
# one controlled charge, redirect, webhook, and refund have been verified.
TAP_SECRET_KEY=
TAP_BASE_URL=https://api.tap.company/v2

# Firebase Auth is still used for login/token verification in the current app.
# Keep this until auth is fully migrated to Supabase Auth.
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_SERVICE_ACCOUNT_JSON=
ADMIN_UIDS=
BOOTSTRAP_ADMIN_EMAILS=

# Salla webhook.
STORE_WEBHOOK_SECRET=
STORE_WEBHOOK_OWNER_UID=
STORE_WEBHOOK_DEFAULT_MAINTENANCE_MONTHS=3
STORE_WEBHOOK_CREATE_BOOKINGS=true
STORE_WEBHOOK_DEFAULT_TECHNICIAN_ID=
STORE_WEBHOOK_DEFAULT_TECHNICIAN_NAME=

# Salla OAuth + API sync.
SALLA_AUTH_MODE=easy
SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=
SALLA_REDIRECT_URI=https://crm.breexe-pro.com/api/integrations/salla/callback
SALLA_SCOPES=offline_access orders.read
SALLA_SYNC_CRON_ENABLED=true
SALLA_SYNC_CRON_SCHEDULE=*/15 * * * *
SALLA_SYNC_MAX_PAGES=3
SALLA_SYNC_PAGE_SIZE=50
SALLA_STATE_SECRET=
SALLA_APP_WEBHOOK_SECRET=
SALLA_APP_OWNER_UID=

# Scheduled reminders.
ENABLE_DAILY_CRON=true
REMINDER_CRON_SCHEDULE=0 10 * * *

# WhatsApp.
# Use cloud_api for Cloud Run/hosted production. Use web only on a VPS with persistent session storage.
WHATSAPP_PROVIDER=cloud_api
WHATSAPP_CLOUD_API_VERSION=v23.0
WHATSAPP_CLOUD_PHONE_NUMBER_ID=
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_CLOUD_TEMPLATE_NAME=
WHATSAPP_CLOUD_TEMPLATE_LANGUAGE=ar

# Cloudflare DNS automation for crm.breexe-pro.com.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_NAME=breexe-pro.com
CLOUDFLARE_RECORD_NAME=crm
CLOUDFLARE_RECORD_TYPE=CNAME
CLOUDFLARE_DNS_TARGET=
CLOUDFLARE_PROXIED=false

# ── Telephony / phone gateway ──
TELEPHONY_PROVIDER=unifonic
TELEPHONY_RING_TIMEOUT_SEC=20
# Generate: openssl rand -hex 24
TELEPHONY_WEBHOOK_SECRET=
# Public HTTPS base URL the providers/phone reach (your domain).
PUBLIC_BASE_URL=
# Legacy MacroDroid token and fallback pairing signer.
GATEWAY_TOKEN=
# Recommended: openssl rand -hex 32 — never place this value in the APK.
GATEWAY_DEVICE_HMAC_SECRET=
GOOGLE_CONTACTS_CLIENT_ID=
GOOGLE_CONTACTS_CLIENT_SECRET=
GOOGLE_CONTACTS_REDIRECT_URI=https://crm.example.com/api/integrations/google-contacts/callback
GOOGLE_CONTACTS_ENCRYPTION_KEY=
GATEWAY_PAIRING_RATE_LIMIT_MAX=10
GATEWAY_ROUTING_MODE=menu
GATEWAY_REPLY_COOLDOWN_MIN=10
WHATSAPP_AUTO_REJECT_CALLS=false
# Persistent SQLite path — mount a volume here (Docker/VPS).
