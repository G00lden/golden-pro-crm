{
  "name": "golden-pro-crm",
  "private": true,
  "version": "1.3.3",
  "type": "module",
  "scripts": {
    "dev": "node scripts/start-server.mjs --dev",
    "start": "node scripts/start-server.mjs",
    "start:prod:win": "npm run start",
    "prebuild": "npm run release:validate",
    "build": "node scripts/build.mjs",
    "release:validate": "node scripts/validate-release.mjs",
    "test:version": "node --test scripts/version-policy.test.mjs",
    "test:auth-policy": "tsx --test server/localAuthPolicy.test.ts",
    "test:server-mode": "node --test scripts/server-mode.test.mjs",
    "test:financial": "tsx --test shared/financial.test.ts",
    "test:schema": "node --test scripts/schema-migration.test.mjs",
    "test:date": "tsx --test shared/date.test.ts",
    "test:validation": "tsx --test server/crmValidation.test.ts",
    "test:user-validation": "tsx --test server/userValidation.test.ts",
    "test:identity": "node --test scripts/user-identity.test.mjs",
    "test:unit": "node scripts/run-unit-tests.mjs",
    "test:integration": "node scripts/ci-integration.mjs",
    "preview": "vite preview",
    "test:smoke": "node scripts/smoke.mjs",
    "salla:webhooks": "node scripts/salla-reconcile-webhooks.mjs",
    "test:golden": "node scripts/golden-path.mjs",
    "test:products": "node --import tsx --test server/productCatalog.test.ts",
    "sync:salla-products": "node --import tsx scripts/sync-salla-products.ts",
    "doctor": "node scripts/doctor.mjs",
    "doctor:prod": "node scripts/doctor.mjs --production",
    "env:prod": "node scripts/create-production-env.mjs",
    "db:verify": "node scripts/supabase-verify.mjs",
    "security:audit": "node scripts/security-audit.mjs",
    "security:source": "node scripts/security-audit.mjs --source-only",
    "security:dependencies": "npm audit --omit=optional --audit-level=moderate",
    "pixel:audit": "node scripts/pixel-audit.mjs",
    "preflight:prod": "node scripts/preflight-production.mjs",
    "deploy:firestore": "firebase deploy --only firestore",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:firebase": "firebase deploy --only hosting,firestore",
    "deploy:cloudrun": "gcloud run deploy golden-pro-crm --source . --region me-central1 --allow-unauthenticated",
    "cloudflare:dns": "node scripts/cloudflare-dns.mjs",
    "ops:start-local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-crm-local-stack.ps1",
    "ops:register-startup": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/register-crm-local-stack-task.ps1 -StartNow",
    "deploy:vps": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/deploy-vps.ps1",
    "clean": "node -e \"for(const p of ['dist','dist-server'])require('fs').rmSync(p,{recursive:true,force:true})\"",
    "clean:win": "powershell -NoProfile -Command \"Remove-Item -Recurse -Force dist,dist-server -ErrorAction SilentlyContinue\"",
    "lint": "tsc --noEmit",
    "supervisor:precheck": "node scripts/supervisor-precheck.mjs",
    "supervisor:checklist": "node scripts/supervisor-checklist-stats.mjs",
    "backup:now": "node scripts/backup-now.mjs",
    "restore:latest": "node scripts/restore-latest-backup.mjs"
  },
  "dependencies": {
    "@google-cloud/firestore": "^8.6.0",
    "@hapi/boom": "^10.0.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-react": "^5.0.4",
    "@whiskeysockets/baileys": "^6.7.19",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "firebase-admin": "^14.1.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "node-cron": "^4.2.1",
    "pino": "^9.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.1",
    "playwright-core": "^1.61.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.23.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  },
  "overrides": {
    "protobufjs": "7.6.4"
  }
}
